# Keep the Composer (PHP) distribution lean — none of the following ship in
# `composer require` tarballs. The Node port and dev files stay in the git repo
# but are excluded from the packaged PHP release.
/tests            export-ignore
/examples         export-ignore
/web-example      export-ignore
/node             export-ignore
/.gitattributes   export-ignore
/.gitignore       export-ignore
/.editorconfig    export-ignore
/CONTRIBUTING.md  export-ignore
/phpstan.neon     export-ignore
/.php-cs-fixer.dist.php export-ignore
/phpdoc.dist.xml  export-ignore
/.github          export-ignore
