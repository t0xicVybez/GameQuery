{
  "name": "@t0xicvybez/gamequery",
  "version": "0.3.0",
  "description": "Dependency-free game server query library (players, map, ping, rules) over UDP/TCP with concurrent multi-server polling. Node/TypeScript port of GameQuery.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gamequery": "dist/bin/gamequery.js"
  },
  "files": [
    "dist",
    "!dist/tests",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node dist/tests/smoke.test.js",
    "test:integration": "tsc && node dist/tests/integration.test.js",
    "fuzz": "tsc && node dist/tests/fuzz.test.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "docs": "typedoc"
  },
  "keywords": [
    "game-server",
    "query",
    "a2s",
    "source",
    "minecraft",
    "steam",
    "gamedig",
    "status"
  ],
  "author": "t0xicVybez",
  "license": "MIT",
  "homepage": "https://github.com/t0xicVybez/GameQuery/tree/main/node",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t0xicVybez/GameQuery.git",
    "directory": "node"
  },
  "bugs": {
    "url": "https://github.com/t0xicVybez/GameQuery/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.7.0",
    "prettier": "^3.4.0",
    "typedoc": "^0.28.20",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
